#!/bin/bash

tmux_directories=""

tmux_file="start-tmux-sessions-for"

open -a Docker && echo "Waiting for Docker Desktop to be ready..." && while ! docker info > /dev/null 2>&1; do sleep 1; done &&

for tmux_directory in */; do
  pushd ${tmux_directory}

  tmux new-session -d -s "${tmux_directory}"

  if [ -f $tmux_file ]; then
     ./start-tmux-sessions-for
  fi

  popd
done
